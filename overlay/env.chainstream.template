# ============================================================
# ChainStream Service — env overlay
# ============================================================
# This file LAYERS on top of the framework's backend/.env.template.
# The framework template ships with every key emptied; this overlay
# pre-fills only the keys whose CORRECT VALUE is part of the
# ChainStream service identity (brand prefix, default profile, etc.).
# Secrets (TG token, LLM keys, webhook URLs) stay empty — the
# operator fills them post-install in /opt/agentflow/backend/.env.
# ============================================================

# ---------- ChainStream identity ----------
# Pre-pinned: this deployment serves the ChainStream brand.
AGENTFLOW_DEFAULT_TOPIC_PROFILE=chainstream
# Brand prefix on every Lark notification card title so a multi-tenant
# Lark group can tell ChainStream notifications apart at a glance.
LARK_WEBHOOK_BRAND_PREFIX=[ChainStream]

# ---------- ChainStream operational defaults ----------
# Twice-daily hotspots scan, top-3 (suitable for a B2B infra brand
# that doesn't need high-frequency content drops).
AGENTFLOW_HOTSPOTS_SCHEDULE=09:00,20:00
AGENTFLOW_HOTSPOTS_SCHEDULE_TOP_K=3

# Real-mode by default. Operators flip MOCK_LLM=true only for smoke
# tests on a fresh install; production never runs with mocks.
MOCK_LLM=false

# Lark "自定义关键词" anchor — keep "AgentFlow" so the bot accepts
# notifications without per-card keyword fuss. Operator may add more
# (e.g. "ChainStream") at the Lark group level + here.
LARK_WEBHOOK_KEYWORDS=AgentFlow

# v1.0.21+ topic-fit hard gate. Hotspots whose Jaccard fit against
# the active publisher (chainstream) tokens is below this score get
# DROPPED before D2 reads them — stops off-domain hotspots (TCG
# customs, e-commerce ops, etc.) from being force-grafted into
# ChainStream-themed articles. 0.05 = any tiny token overlap survives;
# pure mismatches gone. Tune up to 0.10 for stricter brand discipline.
AGENTFLOW_TOPIC_FIT_HARD_THRESHOLD=0.05

# v1.0.22+ pre-cluster signal-level domain filter. Drops individual
# upstream signals (twitter post / RSS item / HN story) whose Jaccard
# overlap with chainstream domain tokens is below the threshold,
# BEFORE clustering. Stops broad-tech KOLs and generic AI tweets from
# shaping clusters in the first place — the v1.0.21 gate would
# eventually clean them out, but they distort the centroids on the
# way through. Default 0.03 for chainstream (any token overlap
# survives; pure noise gone).
AGENTFLOW_SIGNAL_DOMAIN_THRESHOLD=0.03

# v1.0.22+ KOL allowlist mode. With the seeded sources.yaml above,
# generalist accounts (@sama / @paulg / @karpathy / @simonw / @patrickc
# / @dhh) are already marked weight=blocked; this flag adds a second
# layer that suppresses anything below "high" weight too. Result: only
# @VitalikButerin gets fetched out of the box. Operator opens up the
# medium-weight crypto KOLs by either flipping to false or promoting
# them to weight=high.
AGENTFLOW_TWITTER_KOL_ONLY_HIGH=false

# ---------- Operator must fill (intentionally empty in the overlay) ----------
# These do not ship in the overlay — the operator fills them in the
# base .env after install. We list them here as a reminder so a fresh
# install can do a config-checklist sweep:
#   TELEGRAM_BOT_TOKEN
#   TELEGRAM_REVIEW_CHAT_ID    (auto-captured on first /start)
#   MOONSHOT_API_KEY           (or ANTHROPIC_API_KEY for Claude)
#   JINA_API_KEY               (embeddings)
#   ATLASCLOUD_API_KEY         (cover images)
#   GHOST_ADMIN_API_URL / GHOST_ADMIN_API_KEY
#   LARK_WEBHOOK_URL           (group bot webhook)
#   LARK_WEBHOOK_SECRET        (group bot signature key, recommended)
#   LARK_WEBHOOK_TG_BOT_URL    (https://t.me/<your_bot_username>)
